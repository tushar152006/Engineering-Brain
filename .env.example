# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ENABLE_LOCAL_REPO_IMPORT=true
MAX_INDEX_FILE_BYTES=250000
INDEX_STORE_PATH=.engineering-brain/index-store.json

# ── Ollama (local LLM + embeddings) ──────────────────────────────────────────
# Install Ollama: https://ollama.com/download
# Then: ollama pull qwen2.5-coder:7b && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
ENABLE_LLM=true
ENABLE_EMBEDDINGS=true
EMBED_BATCH_SIZE=8

# ── Future: Database ──────────────────────────────────────────────────────────
DATABASE_URL=

# ── Future: Queue ─────────────────────────────────────────────────────────────
REDIS_URL=

# ── Future: GitHub App ────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# ── Future: Hosted LLM fallback ───────────────────────────────────────────────
GROQ_API_KEY=

# ── Future: Knowledge Graph ───────────────────────────────────────────────────
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
